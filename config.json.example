{
    "rtsp_url": "rtsp://localhost:8554/nest-cam",
    "model_name": "yolov8n.pt",
    "fps_limit": 10,
    "video_buffer_size": 1,
    "yolo_imgsz": 640,
    "yolo_device": null,
    "tracker_confidence": 0.1,
    "track_buffer": 30,
    "host": "0.0.0.0",
    "port": 8000,
    "log_level": "INFO",
    "log_file": "logs/cctv.log",
    "trigger_mode": "continuous",
    "event_stream_duration": 45,
    "motion_threshold": 0.005,
    "motion_min_contour_area": 500,
    "background_alpha": 0.05,
    "motion_cooldown_frames": 150,
    "motion_roi": null,
    "tripwire_line": [
        [0.2, 0.5],
        [0.8, 0.5]
    ],
    "tripwire_dead_zone_width": 0.05,
    "tripwire_strict_segment": false,
    "db_path": "db/presence.db",
    "snapshot_dir": "snapshots",
    "webhook_urls": [],
    "webhook_timeout": 5
}